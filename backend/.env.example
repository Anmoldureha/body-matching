SUBMISSIONS_STORAGE_PATH=./uploads
REFERENCE_PHOTOS_PATH=./reference_photos
# Qdrant: default is backend/qdrant_data (persistent, no Docker). Set :memory: for in-memory; http://localhost:6333 for Docker/server.
# QDRANT_URL=./qdrant_data
